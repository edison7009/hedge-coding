{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Budget Coder",
  "version": "0.1.0",
  "identifier": "com.budgetcoder.app",
  "build": {
    "frontendDist": "./ui",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Budget Coder",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
