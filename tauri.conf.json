{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hedge Coding",
  "version": "0.1.6",
  "identifier": "com.hedgecoding.desktop",
  "build": {
    "frontendDist": "./src-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },

  "app": {
    "windows": [
      {
        "title": "Hedge Coding",
        "width": 1600,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
